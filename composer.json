{
  "name": "enthusiast/order-pool",
  "description": "Order pool logic",
  "type": "library",
  "require": {
    "php": "^8.4",
    "ext-pcntl": "*",
    "ext-redis": "*",
    "yiisoft/yii-console": "^2.4",
    "psr/log": "^2.0 || ^3.0"
  },
  "autoload": {
    "psr-4": {
      "Enthusiast\\OrderPool\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Konstantin Popov",
      "email": "konstantin.icreative@gmail.com"
    }
  ],
  "extra": {
    "config-plugin-options": {
      "source-directory": "config"
    },
    "config-plugin": {
      "di": "di.php",
      "di-console": "di-console.php",
      "params": "params.php"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "php-http/discovery": false,
      "tbachert/spi": false
    }
  }
}